# 复制本文件为 .env（同目录），填入你的 API key 即可。
# DeepSeek 用户：只填 LLM_API_KEY，其余用默认。
LLM_API_KEY=

# 非 DeepSeek 厂商：取消下面两行注释，按下表填 base_url 与 model。
# 厂商            LLM_BASE_URL                                       LLM_MODEL
# DeepSeek(默认)  https://api.deepseek.com/v1                        deepseek-chat
# 智谱(免费档)    https://open.bigmodel.cn/api/paas/v4               glm-4-flash
# 通义千问        https://dashscope.aliyuncs.com/compatible-mode/v1  qwen-plus
# Moonshot/Kimi   https://api.moonshot.cn/v1                         moonshot-v1-8k
# OpenAI          https://api.openai.com/v1                          gpt-4o-mini
# LLM_BASE_URL=
# LLM_MODEL=
